# Copy this file to .env and fill in your values
# This file is safe to commit to GitHub (no real secrets)

PORT=5001

# MongoDB Atlas connection string (leave empty to use local JSON file database)
MONGODB_URI=

# Google Gemini AI API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Serper.dev Google Search API key — https://serper.dev
SERPER_API_KEY=

# (Optional) Brave Search API key
BRAVE_SEARCH_API_KEY=
